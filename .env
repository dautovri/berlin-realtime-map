# Fastlane/App Store Connect credentials (placeholders)
APP_STORE_CONNECT_API_KEY_JSON_PATH=./fastlane/AppStoreConnect_API_Key.json
APP_STORE_CONNECT_KEY_ID=REPLACE_ME_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=REPLACE_ME_ISSUER_ID
APP_STORE_CONNECT_KEY_FILEPATH=./fastlane/AuthKey_REPLACE_ME.p8
TEAM_ID=REPLACE_ME_TEAM_ID
EXPORT_TEAM_ID=REPLACE_ME_TEAM_ID

# asc (App Store Connect CLI) credentials (placeholders)
# Docs: https://github.com/rudrankriyam/App-Store-Connect-CLI
ASC_KEY_ID=REPLACE_ME_KEY_ID
ASC_ISSUER_ID=REPLACE_ME_ISSUER_ID
ASC_PRIVATE_KEY_PATH=./fastlane/AuthKey_REPLACE_ME.p8

# Optional but convenient defaults (non-secret)
ASC_APP_ID=6757723208
ASC_VENDOR_NUMBER=REPLACE_ME_VENDOR_NUMBER

# Recommended for CI/scripts (forces config/env auth; avoids Keychain prompts)
ASC_BYPASS_KEYCHAIN=1

# Fail fast if credentials resolve from mixed sources (Keychain + env + config)
ASC_STRICT_AUTH=true
